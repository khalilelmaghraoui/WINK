{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "rootDir": ".",
    "outDir": ".test-dist",
    "noEmit": false
  },
  "include": ["src/lib/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules"]
}
